# Copy this file to ".env" on the server and fill in real values.
# The .env file is git-ignored and must never be committed.

# Generate a fresh one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me-to-a-long-random-string

# Must be False in production. For LOCAL development set this to True,
# otherwise the HTTPS redirect + secure-cookie settings will break runserver.
DEBUG=False

# Comma-separated hostnames this site is served on (no scheme, no slash).
ALLOWED_HOSTS=YOUR-SUBDOMAIN.duckdns.org
